<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/authFragment">
    <fragment
        android:id="@+id/authFragment"
        android:name="com.example.transportguide.AuthFragment"
        android:label="Вход" >
        <action
            android:id="@+id/action_authFragment_to_mainFragment"
            app:destination="@id/mainFragment"
            app:popUpTo="@id/authFragment"
            app:popUpToInclusive="true" /> <!-- Чтобы нельзя было вернуться назад к логину -->
    </fragment>
    <fragment
        android:id="@+id/mainFragment"
        android:name="com.example.transportguide.MainFragment"
        android:label="Main" >
        <action
            android:id="@+id/action_mainFragment_to_detailFragment"
            app:destination="@id/detailFragment" />
        <action
            android:id="@+id/action_mainFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
        <argument
            android:name="routeId"
            app:argType="integer"
            android:defaultValue="-1" />
        <argument
            android:name="number"
            app:argType="string"
            android:defaultValue='""' />
        <argument
            android:name="desc"
            app:argType="string"
            android:defaultValue='""' />
        <argument
            android:name="imageUrl"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
    </fragment>

    <fragment
        android:id="@+id/detailFragment"
        android:name="com.example.transportguide.DetailFragment"
        android:label="Detail" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.transportguide.SettingsFragment"
        android:label="Settings" />
        <action
            android:id="@+id/action_settingsFragment_to_authFragment"
            app:destination="@id/authFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
</navigation>